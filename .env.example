# ============================================================
#  Userbot Panel - environment configuration
#  Copy this file to ".env" and fill in real values.
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database ---
# SQLite (default, good for development):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (recommended for production):
# DATABASE_URL=postgres://user:password@localhost:5432/userbot_panel

# --- Encryption ---
# Fernet key used to encrypt Telegram session strings at rest.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Telegram API credentials (https://my.telegram.org) ---
# Used as the default app credentials when connecting accounts.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Email (for sending API keys to developers) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@userbot-panel.local

# --- Notifier account ---
# Optional: phone of a connected account used to deliver API keys / notifications
# to developers over Telegram. If empty, only email is used.
NOTIFIER_ACCOUNT_PHONE=
